# Copy to .env and chmod 600. Never commit .env.

COMPOSE_PROJECT_NAME=km0-mail

# Service identity
MAIL_HOSTNAME=mail.km0digital.com
MAIL_DOMAIN=km0digital.com

# PostgreSQL
POSTGRES_USER=mail
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=mail

# Roundcube database (separate schema in same instance)
ROUNDCUBE_DB_NAME=roundcube
ROUNDCUBE_DB_USER=roundcube
ROUNDCUBE_DB_PASSWORD=change-me-roundcube

# Postfix/Dovecot SQL user (limited grants)
MAIL_DB_USER=mail
MAIL_DB_PASSWORD=change-me-mail-db

# Roundcube installer (first boot only; remove after init)
ROUNDCUBE_DES_KEY=change-me-roundcube-des-key

# Dex OIDC SSO (shared issuer: cloud.km0digital.com/dex)
# Generate with: openssl rand -hex 32
ROUNDCUBE_OAUTH_CLIENT_ID=km0-mail-web
ROUNDCUBE_OAUTH_CLIENT_SECRET=change-me-roundcube-oauth-secret
DOVECOT_OAUTH_CLIENT_ID=km0-mail-dovecot
DOVECOT_OAUTH_CLIENT_SECRET=change-me-dovecot-oauth-secret
MAIL_PROVISION_API_TOKEN=change-me-provision-api-token
DEX_INTROSPECTION_URL=https://cloud.km0digital.com/dex/token/introspect
