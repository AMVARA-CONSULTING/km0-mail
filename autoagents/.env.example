# GitHub + autoagents (optional — copy to .env, never commit)

# Fine-grained PAT for Luipy56 with Issues read/write on km0-mail
# GH_TOKEN=ghp_...

AGENT_GH_REPO=AMVARA-CONSULTING/km0-mail
AGENT_GIT_BRANCH=main

# Committer: set 1 to invoke 040-committer via cursor-agent (full committer)
AGENT_COMMITTER_USE_CURSOR=1

# Redmine closing notes (optional — posts Textile summary when archiving CLOSED tasks)
# REDMINE_URL=https://redmine.amvara.de
# REDMINE_API_KEY=
# REDMINE_ISSUE_ID=7605

# Runtime digest (inside repo; default autoagents/var/loop)
# AGENT_LOOP_TMP=autoagents/var/loop
