#!/usr/bin/env bash
# km0-mail-admin — provision mailboxes and aliases for @km0digital.com
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

if [[ ! -f .env ]]; then
    echo "error: .env missing — copy .env.example and set secrets" >&2
    exit 1
fi

# shellcheck disable=SC1091
source .env

MAIL_DOMAIN="${MAIL_DOMAIN:-km0digital.com}"
COMPOSE="docker compose"

usage() {
    cat <<EOF
Usage: $0 <command> [args]

Commands:
  create-mailbox <user@km0digital.com> [password]
  create-alias <alias@km0digital.com> <target@km0digital.com>
  list-mailboxes
  list-aliases
  set-password <user@km0digital.com> [password]
  provision-sso-mailbox <user@km0digital.com> [opencloud_uuid] [password]

If password is omitted, a random password is generated and printed once.
provision-sso-mailbox calls the localhost provision API (SSO / register hook).
EOF
}

require_email() {
    local email="$1"
    if [[ ! "$email" =~ @${MAIL_DOMAIN}$ ]]; then
        echo "error: address must end with @${MAIL_DOMAIN}" >&2
        exit 1
    fi
}

gen_password() {
    openssl rand -base64 18 | tr -d '/+=' | head -c 16
}

hash_password() {
    local plain="$1"
    $COMPOSE exec -T dovecot doveadm pw -s BLF-CRYPT -p "$plain" | tr -d '\r'
}

psql_exec() {
    $COMPOSE exec -T postgres psql -v ON_ERROR_STOP=1 -U "$POSTGRES_USER" -d "$POSTGRES_DB" "$@"
}

reload_postfix_maps() {
    $COMPOSE exec -T postfix build-hash-maps.sh >/dev/null
}

cmd_create_mailbox() {
    local email="$1"
    local password="${2:-$(gen_password)}"
    require_email "$email"

    local hash
    hash="$(hash_password "$password")"

    psql_exec -c \
        "INSERT INTO mail_accounts (email, password_hash) VALUES ('${email}', '${hash}')
         ON CONFLICT (email) DO UPDATE SET password_hash=EXCLUDED.password_hash, active=TRUE, updated_at=NOW();"

    local local_part domain maildir
    local_part="${email%@*}"
    domain="${email#*@}"
    maildir="/var/mail/vhosts/${domain}/${local_part}"
    $COMPOSE exec -T dovecot sh -c "mkdir -p ${maildir}/{cur,new,tmp} && chown -R vmail:vmail ${maildir}"

    reload_postfix_maps

    echo "mailbox: ${email}"
    if [[ -z "${2:-}" ]]; then
        echo "password: ${password}"
    fi
}

cmd_set_password() {
    local email="$1"
    local password="${2:-$(gen_password)}"
    require_email "$email"

    local hash
    hash="$(hash_password "$password")"
    psql_exec -c \
        "UPDATE mail_accounts SET password_hash='${hash}', updated_at=NOW() WHERE email='${email}';"

    echo "password updated: ${email}"
    if [[ -z "${2:-}" ]]; then
        echo "password: ${password}"
    fi
}

cmd_create_alias() {
    local alias="$1"
    local target="$2"
    require_email "$alias"
    require_email "$target"

    psql_exec -c \
        "INSERT INTO mail_aliases (alias_address, target_email) VALUES ('${alias}', '${target}')
         ON CONFLICT (alias_address) DO UPDATE SET target_email=EXCLUDED.target_email;"
    reload_postfix_maps
    echo "alias: ${alias} -> ${target}"
}

cmd_list_mailboxes() {
    psql_exec -c "SELECT email, active, quota_bytes, opencloud_uuid, created_at FROM mail_accounts ORDER BY email;"
}

cmd_list_aliases() {
    psql_exec -c "SELECT alias_address, target_email, created_at FROM mail_aliases ORDER BY alias_address;"
}

cmd_provision_sso_mailbox() {
    local email="$1"
    local opencloud_uuid="${2:-}"
    local password="${3:-}"
    require_email "$email"

    : "${MAIL_PROVISION_API_TOKEN:?MAIL_PROVISION_API_TOKEN required in .env}"
    local api_url="${KM0_PROVISION_API_URL:-http://127.0.0.1:8092}"

    local payload
    if [[ -n "$opencloud_uuid" && -n "$password" ]]; then
        payload=$(printf '{"email":"%s","opencloud_uuid":"%s","password":"%s"}' "$email" "$opencloud_uuid" "$password")
    elif [[ -n "$opencloud_uuid" ]]; then
        payload=$(printf '{"email":"%s","opencloud_uuid":"%s"}' "$email" "$opencloud_uuid")
    elif [[ -n "$password" ]]; then
        payload=$(printf '{"email":"%s","password":"%s"}' "$email" "$password")
    else
        payload=$(printf '{"email":"%s"}' "$email")
    fi

    local http_code
    http_code=$(curl -sf -o /tmp/km0-provision.json -w '%{http_code}' \
        -X POST "${api_url}/provision" \
        -H "Authorization: Bearer ${MAIL_PROVISION_API_TOKEN}" \
        -H "Content-Type: application/json" \
        -d "$payload") || {
        echo "error: provision API request failed" >&2
        exit 1
    }

    if [[ "$http_code" != "200" && "$http_code" != "201" ]]; then
        echo "error: provision API returned HTTP ${http_code}" >&2
        cat /tmp/km0-provision.json >&2 2>/dev/null || true
        exit 1
    fi

    echo "provisioned: ${email} (HTTP ${http_code})"
    cat /tmp/km0-provision.json
}

main() {
    local cmd="${1:-}"
    case "$cmd" in
        create-mailbox)
            [[ $# -ge 2 ]] || { usage; exit 1; }
            cmd_create_mailbox "$2" "${3:-}"
            ;;
        set-password)
            [[ $# -ge 2 ]] || { usage; exit 1; }
            cmd_set_password "$2" "${3:-}"
            ;;
        create-alias)
            [[ $# -ge 3 ]] || { usage; exit 1; }
            cmd_create_alias "$2" "$3"
            ;;
        list-mailboxes)
            cmd_list_mailboxes
            ;;
        list-aliases)
            cmd_list_aliases
            ;;
        provision-sso-mailbox)
            [[ $# -ge 2 ]] || { usage; exit 1; }
            cmd_provision_sso_mailbox "$2" "${3:-}" "${4:-}"
            ;;
        -h|--help|help|"")
            usage
            ;;
        *)
            echo "error: unknown command: $cmd" >&2
            usage
            exit 1
            ;;
    esac
}

main "$@"
